# Database
DATABASE_URL="file:./dev.db"

# JWT Secret (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET="your-jwt-secret-here"

# Stripe Keys (get from https://dashboard.stripe.com/apikeys)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_your_publishable_key"
STRIPE_SECRET_KEY="sk_test_your_secret_key"

# Email Configuration
# Choose your email provider: 'resend' or 'nodemailer'
EMAIL_PROVIDER="nodemailer"

# Resend (easiest but requires paid plan for multiple recipients)
RESEND_API_KEY="re_..."

# Nodemailer / SMTP (works with Gmail, Outlook, etc - FREE for unlimited recipients)
# For Gmail: Enable 2FA and create an App Password at https://myaccount.google.com/apppasswords
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password-here"

# Sender email and app URL
FROM_EMAIL="noreply@justcases.bg"

# Optional: For production
# NODE_ENV="production"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
ALLOWED_ORIGINS="http://localhost:3000"
# Optional dedicated secret for signed newsletter unsubscribe links (falls back to JWT_SECRET)
NEWSLETTER_UNSUBSCRIBE_SECRET=""

# Google OAuth (get from https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Optional: Upstash Redis (distributed rate limiting/cache)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
# Optional: in production, fail closed (block) auth/payment/internal routes if Redis limit checks fail
RATE_LIMIT_FAIL_CLOSED="false"

# Rate limiting proxy trust (keep defaults unless behind trusted proxies)
TRUST_X_FORWARDED_FOR="false"
# Number of trusted proxies in front of your app when TRUST_X_FORWARDED_FOR=true
TRUSTED_PROXY_COUNT="0"

# Required when Redis queue worker is enabled
# Send this as x-worker-secret to /api/internal/jobs/email/drain
JOB_WORKER_SECRET=""

# Optional dedicated secret for /api/internal/health (falls back to JOB_WORKER_SECRET)
HEALTHCHECK_SECRET=""
